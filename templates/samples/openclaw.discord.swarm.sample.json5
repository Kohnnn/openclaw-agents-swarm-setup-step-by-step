{
  // OpenClaw Discord Swarm sample config (replace placeholders)
  session: {
    dmScope: "per-account-channel-peer",
  },

  agents: {
    defaults: {
      subagents: {
        maxSpawnDepth: 2,
        maxChildrenPerAgent: 5,
        runTimeoutSeconds: 900,
        archiveAfterMinutes: 60,
      },
    },
    list: [
      {
        id: "orchestrator",
        workspace: "~/.openclaw/workspace-orchestrator",
        model: { primary: "anthropic/claude-opus-4-6" },
      },
      {
        id: "sub1",
        workspace: "~/.openclaw/workspace-sub1",
        model: { primary: "openai/gpt-5.1-codex" },
      },
      {
        id: "sub2",
        workspace: "~/.openclaw/workspace-sub2",
        model: { primary: "openrouter/anthropic/claude-sonnet-4-5" },
      },
      {
        id: "sub3",
        workspace: "~/.openclaw/workspace-sub3",
        model: { primary: "qwen-portal/coder-model" },
      },
      {
        id: "reviewer",
        workspace: "~/.openclaw/workspace-reviewer",
        model: { primary: "openai-codex/gpt-5.3-codex" },
      },
    ],
  },

  channels: {
    discord: {
      accounts: {
        orchestrator: {
          token: "${DISCORD_TOKEN_ORCHESTRATOR}",
          // replace with your actual server/guild and channel IDs
          guildAllowlist: ["<DISCORD_GUILD_ID>"],
          channelAllowlist: [
            "<CHANNEL_ID_INBOX_USER>",
            "<CHANNEL_ID_BRAINSTORM_ORCHESTRATOR>",
          ],
        },
        sub1: {
          token: "${DISCORD_TOKEN_SUB1}",
          guildAllowlist: ["<DISCORD_GUILD_ID>"],
          channelAllowlist: ["<CHANNEL_ID_WORK_SUB1>"],
        },
        sub2: {
          token: "${DISCORD_TOKEN_SUB2}",
          guildAllowlist: ["<DISCORD_GUILD_ID>"],
          channelAllowlist: ["<CHANNEL_ID_WORK_SUB2>"],
        },
        sub3: {
          token: "${DISCORD_TOKEN_SUB3}",
          guildAllowlist: ["<DISCORD_GUILD_ID>"],
          channelAllowlist: ["<CHANNEL_ID_WORK_SUB3>"],
        },
        reviewer: {
          token: "${DISCORD_TOKEN_REVIEWER}",
          guildAllowlist: ["<DISCORD_GUILD_ID>"],
          channelAllowlist: [
            "<CHANNEL_ID_REVIEWER_GATE>",
            "<CHANNEL_ID_RELEASE_READY>",
          ],
        },
      },
    },
  },

  bindings: [
    {
      agentId: "orchestrator",
      match: {
        channel: "discord",
        accountId: "orchestrator",
      },
    },
    {
      agentId: "sub1",
      match: {
        channel: "discord",
        accountId: "sub1",
      },
    },
    {
      agentId: "sub2",
      match: {
        channel: "discord",
        accountId: "sub2",
      },
    },
    {
      agentId: "sub3",
      match: {
        channel: "discord",
        accountId: "sub3",
      },
    },
    {
      agentId: "reviewer",
      match: {
        channel: "discord",
        accountId: "reviewer",
      },
    },
  ],

  env: {
    OPENAI_API_KEY: "${OPENAI_API_KEY}",
    ANTHROPIC_API_KEY: "${ANTHROPIC_API_KEY}",
    OPENROUTER_API_KEY: "${OPENROUTER_API_KEY}",
  },
}
